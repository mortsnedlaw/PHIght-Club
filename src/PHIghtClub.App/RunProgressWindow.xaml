<Window x:Class="PHIghtClub.App.RunProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Run Progress" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0">
    <Grid Margin="12">
        <StackPanel VerticalAlignment="Stretch">
            <!-- Job Info -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#333">Job ID</TextBlock>
                <TextBlock x:Name="JobIdText" FontSize="12" Foreground="#666" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Current Action -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#333">Current Action</TextBlock>
                <TextBlock x:Name="CurrentActionText" FontSize="12" Foreground="#666" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Current File -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#333">Current File</TextBlock>
                <TextBlock x:Name="CurrentFileText" FontSize="12" Foreground="#666" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Progress Bar -->
            <ProgressBar x:Name="ProgressBar" Height="20" Foreground="#0078D4" Margin="0,0,0,12"/>

            <!-- Counters -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <TextBlock FontSize="11" Foreground="#666">Processed</TextBlock>
                    <TextBlock x:Name="ProcessedCountText" FontSize="16" FontWeight="Bold" Foreground="#0078D4"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,6,0">
                    <TextBlock FontSize="11" Foreground="#666">Total</TextBlock>
                    <TextBlock x:Name="TotalCountText" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,6,0">
                    <TextBlock FontSize="11" Foreground="#666">Failed</TextBlock>
                    <TextBlock x:Name="FailedCountText" FontSize="16" FontWeight="Bold" Foreground="#D13438"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,6,0">
                    <TextBlock FontSize="11" Foreground="#666">Quarantined</TextBlock>
                    <TextBlock x:Name="QuarantinedCountText" FontSize="16" FontWeight="Bold" Foreground="#FF8C00"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock FontSize="11" Foreground="#666">Exported</TextBlock>
                    <TextBlock x:Name="ExportedCountText" FontSize="16" FontWeight="Bold" Foreground="#107C10"/>
                </StackPanel>
            </Grid>

            <!-- Status Log -->
            <StackPanel VerticalAlignment="Stretch" Margin="0,0,0,12">
                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,4">Status Log</TextBlock>
                <ScrollViewer x:Name="StatusLogScrollViewer" VerticalScrollBarVisibility="Auto" Height="200" BorderThickness="1" BorderBrush="#DDD" Background="White">
                    <TextBlock x:Name="StatusLogText" FontSize="11" Foreground="#333" Padding="8" TextWrapping="Wrap" VerticalAlignment="Top"/>
                </ScrollViewer>
            </StackPanel>

            <!-- Close Button -->
            <Button x:Name="CloseButton" Content="Close" Height="32" Foreground="White" Background="#0078D4" Click="CloseButton_Click" HorizontalAlignment="Right"/>
        </StackPanel>
    </Grid>
</Window>
